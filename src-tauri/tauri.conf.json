{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "리빙룸",
  "version": "0.1.1",
  "identifier": "com.codeworks.livingroom",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "리빙룸",
        "width": 1100,
        "height": 720,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/gimttos/living-room/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxQ0MyNEI3Q0JGRjBEMTcKUldRWERmL0x0eVRNUVpwaEFDRy9SQWx2Y014YjVnY3dXa1d4N3pYTTFZTUpabmQ0cTF4REtQb3kK"
    }
  }
}
